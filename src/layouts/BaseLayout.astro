---
import { SEO } from 'astro-seo';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const {
  title,
  description = 'A reference site on sambal traditions, chili pastes, and Southeast Asian home cooking.',
  navItems = [],
  footerLinks = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title={title} description={description} canonical={canonicalURL} twitter={{ card: 'summary_large_image' }} />
  </head>
  <body>
    <Header title="Cafe Sambal" navItems={navItems} />
    <main>
      <slot />
    </main>
    <Footer domain="cafesambal.com" links={footerLinks} />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #fff8f0;
    --surface: #fffaf5;
    --text: #2f1f15;
    --muted: #6b4f3b;
    --accent: #c2410c;
    --accent-soft: #fdba74;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    background: radial-gradient(circle at top, #fff1e5, var(--bg) 45%);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  main {
    min-height: 70vh;
  }

  .page-shell {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 0;
  }

  h1,
  h2,
  h3 {
    font-family: Georgia, 'Times New Roman', serif;
  }
</style>
