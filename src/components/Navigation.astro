---
const { currentTopic, currentPillar, links = [] } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Breadcrumb navigation">
  <a href="/">Home</a>
  <span>/</span>
  <a href={currentTopic.href}>{currentTopic.label}</a>
  <span>/</span>
  <strong>{currentPillar}</strong>
</nav>

<nav class="pillar-nav" aria-label="Pillar navigation">
  {links.map((link) => (
    <a href={link.href} class={link.active ? 'active' : ''}>{link.label}</a>
  ))}
</nav>

<style>
  .breadcrumbs,
  .pillar-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
  }

  .breadcrumbs {
    color: #7c2d12;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .breadcrumbs a {
    color: #9a3412;
    text-decoration: none;
  }

  .pillar-nav {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(124, 45, 18, 0.12);
  }

  .pillar-nav a {
    text-decoration: none;
    color: #7c2d12;
    font-weight: 600;
    padding: 0.45rem 0.75rem;
    background: #fff7ed;
    border-radius: 999px;
  }

  .pillar-nav a.active {
    background: #fdba74;
    color: #431407;
  }
</style>
