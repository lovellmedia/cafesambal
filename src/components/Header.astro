---
const {
  title = 'Cafe Sambal',
  navItems = [],
} = Astro.props;
---

<header class="site-header">
  <div class="inner">
    <a class="brand" href="/">{title}</a>
    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-nav" onclick="toggleMenu()">
      Menu
    </button>
    <nav id="primary-nav" class="nav" aria-label="Primary navigation">
      {navItems.map((item) => (
        <a href={item.href} class={item.active ? 'active' : ''}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<script is:inline>
  function toggleMenu() {
    const nav = document.getElementById('primary-nav');
    const button = document.querySelector('.menu-toggle');
    if (!nav || !button) return;
    nav.classList.toggle('open');
    const expanded = nav.classList.contains('open');
    button.setAttribute('aria-expanded', String(expanded));
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 248, 240, 0.95);
    border-bottom: 1px solid rgba(139, 69, 19, 0.15);
    backdrop-filter: blur(10px);
  }

  .inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    color: #7c2d12;
    font-size: 1.15rem;
    font-weight: 800;
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .nav {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .nav a {
    color: #7c2d12;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .nav a.active {
    color: #b45309;
  }

  .menu-toggle {
    display: none;
    border: 1px solid rgba(124, 45, 18, 0.2);
    background: #fff7ed;
    color: #7c2d12;
    border-radius: 999px;
    padding: 0.55rem 0.9rem;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .menu-toggle {
      display: inline-flex;
    }

    .nav {
      display: none;
      position: absolute;
      top: calc(100% + 1px);
      left: 0;
      right: 0;
      padding: 1rem 1.5rem 1.25rem;
      background: #fffaf5;
      border-bottom: 1px solid rgba(139, 69, 19, 0.15);
      flex-direction: column;
      align-items: flex-start;
    }

    .nav.open {
      display: flex;
    }
  }
</style>
